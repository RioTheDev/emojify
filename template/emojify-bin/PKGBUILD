# This PKGBUILD is partial. 
# pkgname, pkgver, source, and _checksum are dynamically generated by the python script.
pkgdesc="An emoji picker made to be fast. (GTK4/C++)"
pkgrel=1
arch=('x86_64')
url="https://github.com/RioTheDev/emojify"
license=('GPL3')
depends=('gtkmm-4.0' 'glibmm-2.68' 'libadwaita')

sha256sums=(
  "$_checksum"  # for emojify-${_checksum}.tar.gz
  'SKIP'         # for README.md
  'SKIP'         # for LICENSE.md
)

package() {
  cp -rv "${srcdir}/usr" "${pkgdir}/"
  
  install -Dm644 "${srcdir}/README.md" "${pkgdir}/usr/share/doc/emojify/README.md"
  install -Dm644 "${srcdir}/LICENSE.md" "${pkgdir}/usr/share/licenses/emojify/LICENSE.md"
}